# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
*.pyz
*.pyzw

# Virtual environments (any name)
.venv/
venv/
env/
ENV/
.env/

# ── Golem runtime state ────────────────────────────────
# Created by `golem run` in target projects — never commit
.golem/
sessions/
golem-dashboard.log
*.golem-log

# ── Git worktrees ──────────────────────────────────────
# Worktrees are ephemeral working copies — never tracked.
# Top-level worktree directory (golem + manual usage)
worktrees/
# Common worktree naming patterns (safety net)
wt-*/
worktree-*/
*.worktree/
# Git internal worktree bookkeeping happens in .git — no
# action needed, but prevent stale lock files from landing
*.lock

# ── IDE / Editor ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ── OS artifacts ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Testing ────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
test-results/
playwright-report/

# ── Node / Playwright (UI test tooling only) ──────────
node_modules/
package-lock.json
.npm/
.pnpm-store/

# ── uv ─────────────────────────────────────────────────
uv.lock

# ── Claude Code / Superpowers ──────────────────────────
.claude/settings.json
.claude/settings.local.json
.superpowers/

# ── ZeroShot runtime ─────────────────────────────────
zeroshot/

# ── Logs & temp ────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig
